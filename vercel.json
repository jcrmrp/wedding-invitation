{
  "version": 2,
  "installCommand": "npm install --prefix frontend --legacy-peer-deps",
  "buildCommand": "npm run build --prefix frontend",
  "outputDirectory": "frontend/dist",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
